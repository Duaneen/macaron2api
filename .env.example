# Host port exposed by docker compose.
HOST_PORT=8787

# Application port for local Node or direct docker run.
PORT=8787

# Set a local API key before exposing the service outside localhost.
# Clients can authenticate with "Authorization: Bearer <API_KEY>" or "x-api-key".
API_KEY=change-me

MACARON_ORIGIN=https://macaron-model-previews.macaron.im
MACARON_DEFAULT_MODEL=macaron-v1-preview-b200
MACARON_UPSTREAM_TRANSPORT=auto
MACARON_TIMEOUT_MS=120000
MACARON_MAX_BODY_BYTES=20971520
MACARON_ALLOW_UNKNOWN_MODELS=0

# Used when Vercel returns x-vercel-mitigated: challenge to direct Node requests.
# auto = try direct first, then use a real browser transport for Vercel challenges.
# direct = never start a browser. browser = always use browser transport.
MACARON_BROWSER_EXECUTABLE=
MACARON_BROWSER_USER_DATA_DIR=
MACARON_BROWSER_HEADLESS=1
MACARON_BROWSER_STARTUP_TIMEOUT_MS=30000

# Optional upstream credentials for non-Macaron preview models.
MACARON_UPSTREAM_API_KEY=
MACARON_UPSTREAM_BASE_URL=

CORS_ALLOW_ORIGIN=*
LOG_REQUESTS=1
